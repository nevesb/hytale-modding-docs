{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "npc-flocks",
  "description": "Flock behavior patterns",
  "type": "object",
  "properties": {
    "MaxGrowSize": {
      "type": "integer",
      "minimum": 8,
      "maximum": 8
    },
    "MinSize": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },
    "Size": {
      "type": "array"
    },
    "SizeWeights": {
      "type": "array"
    },
    "Type": {
      "type": "string",
      "examples": [
        "Weighted"
      ]
    }
  },
  "required": [
    "MinSize",
    "SizeWeights",
    "Type"
  ]
}