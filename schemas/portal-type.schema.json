{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "portal-type",
  "description": "Portal configurations linking to instances",
  "type": "object",
  "properties": {
    "Description": {
      "type": "object"
    },
    "InstanceId": {
      "type": "string",
      "examples": [
        "Portals_Hedera",
        "Portals_Henges",
        "Portals_Jungles"
      ]
    },
    "VoidInvasionEnabled": {
      "type": "boolean"
    }
  },
  "required": [
    "Description",
    "InstanceId"
  ]
}